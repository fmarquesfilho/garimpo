{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "ShopId numérico do marketplace (como string)"
    },
    "nome": {
      "type": "string",
      "description": "Nome canônico da loja"
    },
    "nome_normalizado": {
      "type": "string",
      "description": "Nome normalizado para busca"
    },
    "marketplace": {
      "type": "string",
      "description": "Marketplace da loja"
    },
    "cron": {
      "type": ["string", "null"],
      "description": "Expressão cron de monitoramento"
    },
    "origem": {
      "type": ["string", "null"],
      "description": "Origem (país) da loja"
    },
    "monitorada": {
      "type": "boolean",
      "description": "True se possui cron ativo"
    },
    "imagem": {
      "type": ["string", "null"],
      "description": "URL do avatar da loja"
    },
    "seguidores": {
      "type": ["integer", "null"],
      "description": "Número de seguidores"
    },
    "total_produtos": {
      "type": ["integer", "null"],
      "description": "Quantidade total de produtos"
    },
    "avaliacao": {
      "type": ["number", "null"],
      "description": "Avaliação média (0-5)"
    }
  },
  "required": ["id", "nome", "nome_normalizado", "marketplace", "monitorada"],
  "additionalProperties": false
}
