{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID da busca/loja criada"
    },
    "keyword": {
      "type": "string",
      "description": "Nome da loja resolvido ou keyword original"
    },
    "shop_ids": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "IDs numéricos da loja no marketplace"
    },
    "status": {
      "type": "string",
      "enum": ["adicionada"],
      "description": "Status da operação"
    }
  },
  "required": ["id", "keyword", "status"],
  "additionalProperties": false
}
