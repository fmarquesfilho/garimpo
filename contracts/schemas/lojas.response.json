{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "ShopId numérico do marketplace (como string) — chave de escopo da busca. NÃO é o Guid PK do registro."
    },
    "nome": {
      "type": "string",
      "description": "Nome canônico da loja"
    },
    "nome_normalizado": {
      "type": "string",
      "description": "Nome normalizado para busca"
    },
    "marketplace": {
      "type": "string",
      "description": "Marketplace da loja"
    },
    "cron": {
      "type": ["string", "null"],
      "description": "Expressão cron de monitoramento"
    },
    "origem": {
      "type": ["string", "null"],
      "description": "Origem (país) da loja"
    },
    "monitorada": {
      "type": "boolean",
      "description": "True se possui cron ativo"
    }
  },
  "required": ["id", "nome", "nome_normalizado", "marketplace", "monitorada"],
  "additionalProperties": false
}

