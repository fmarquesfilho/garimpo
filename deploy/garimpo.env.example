# Modelo do arquivo de ambiente do backend.
# No servidor, copie para /etc/garimpo/garimpo.env, preencha e proteja:
#   sudo install -d /etc/garimpo
#   sudo cp garimpo.env.example /etc/garimpo/garimpo.env
#   sudo chmod 600 /etc/garimpo/garimpo.env
#   sudo chown garimpo:garimpo /etc/garimpo/garimpo.env
#
# NUNCA versione o arquivo preenchido. Só este .example entra no git.

SHOPEE_APP_ID=coloque_seu_app_id_aqui
SHOPEE_SECRET=coloque_seu_secret_aqui
