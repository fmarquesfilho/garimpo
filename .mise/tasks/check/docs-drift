#!/usr/bin/env bash
#MISE description="Smoke da pipeline de docs: geradores + sync rodam e produzem saída completa"
# =============================================================================
# check/docs-drift — Valida que a pipeline de documentação está saudável.
# =============================================================================
# Desde 2026-07-12 os artefatos gerados NÃO são commitados (ver .gitignore):
#   - docs-site/docs/**      → 100% recriado por `docs/sync`
#   - docs/gerado/{BOARD,ROADMAP,ENTIDADES,env-vars}.md → geradores
# A CI (.github/workflows/docs.yml) regenera tudo (`mise run docs`) antes de
# buildar/deployar, então não há mais "drift" entre fonte e artefato commitado.
#
# Este check virou um SMOKE TEST: regenera + sincroniza e verifica que a saída
# está completa (sidebar válido, ADRs, docs esperados, links do index resolvem).
# Não faz git diff nem exige nada commitado. Exit 1 = pipeline quebrada.
#
# Fontes → geradores:
#   - backlog/tasks/*.yaml → BOARD.md, ROADMAP.md   (cmd/gen-board)
#   - internal/store/      → ENTIDADES.md            (cmd/gen-er)
#   - deploy/, services/   → env-vars.md             (.mise/tasks/docs/env)
#   - docs/**, backlog/**  → docs-site/docs/**       (.mise/tasks/docs/sync)
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'
ERRORS=0

echo "═══════════════════════════════════════════════════════════════"
echo "  Docs Pipeline Smoke"
echo "═══════════════════════════════════════════════════════════════"
echo ""

# ── 1. Regenerar docs/gerado/ (falha do gerador aborta via set -e) ────────────
echo "🔍 Regenerando docs gerados..."
go run ./cmd/gen-board > /dev/null 2>&1
go run ./cmd/gen-er > docs/gerado/ENTIDADES.md 2>/dev/null
bash .mise/tasks/docs/env > /dev/null 2>&1 || true
bash .mise/tasks/gen/api-reference > /dev/null 2>&1 || true
echo -e "${GREEN}   ✓ Geradores executaram${NC}"

# ── 2. Rodar docs/sync (recria docs-site/docs a partir das fontes) ────────────
echo ""
echo "🔍 Verificando docs/sync..."
if ! bash .mise/tasks/docs/sync > /dev/null 2>&1; then
  echo -e "${RED}   ✗ docs/sync falhou${NC}"
  ERRORS=$((ERRORS + 1))
else
  echo -e "${GREEN}   ✓ docs/sync executou com sucesso${NC}"
fi

# ── 3. Verificar que todos os docs esperados existem após sync ────────────────
echo ""
echo "🔍 Verificando completude do docs-site..."
MISSING=0

# Sidebar gerado deve existir e ser JSON válido
if [ ! -f "docs-site/docs/_sidebar.json" ]; then
  echo -e "${RED}   ✗ Faltando: _sidebar.json${NC}"
  MISSING=$((MISSING + 1))
elif ! python3 -c "import json; json.load(open('docs-site/docs/_sidebar.json'))" 2>/dev/null; then
  echo -e "${RED}   ✗ _sidebar.json é JSON inválido${NC}"
  MISSING=$((MISSING + 1))
else
  echo -e "${GREEN}   ✓ _sidebar.json válido${NC}"
fi

# Todas as ADRs devem ser copiadas
ADR_SOURCE=$(ls docs/decisoes/*.md 2>/dev/null | wc -l | tr -d ' ')
ADR_DEST=$(ls docs-site/docs/decisoes/*.md 2>/dev/null | wc -l | tr -d ' ')
if [ "$ADR_SOURCE" -ne "$ADR_DEST" ]; then
  echo -e "${RED}   ✗ ADRs: $ADR_SOURCE fontes vs $ADR_DEST no docs-site${NC}"
  MISSING=$((MISSING + 1))
else
  echo -e "${GREEN}   ✓ $ADR_DEST ADRs sincronizadas${NC}"
fi

# Docs gerados devem existir (regenerados no passo 1 + copiados pelo sync)
for f in BOARD.md ROADMAP.md ENTIDADES.md env-vars.md; do
  if [ ! -f "docs-site/docs/gerado/$f" ]; then
    echo -e "${RED}   ✗ Faltando: gerado/$f${NC}"
    MISSING=$((MISSING + 1))
  fi
done

# Frontend docs devem existir
for f in componentes.md impacto-migracao-ui.md; do
  if [ ! -f "docs-site/docs/frontend/$f" ]; then
    echo -e "${RED}   ✗ Faltando: frontend/$f${NC}"
    MISSING=$((MISSING + 1))
  fi
done

# Sprint
if [ ! -f "docs-site/docs/projeto/sprint.md" ]; then
  echo -e "${RED}   ✗ Faltando: projeto/sprint.md${NC}"
  MISSING=$((MISSING + 1))
fi

if [ "$MISSING" -eq 0 ]; then
  echo -e "${GREEN}   ✓ Todos os docs esperados presentes${NC}"
else
  ERRORS=$((ERRORS + MISSING))
fi

# ── 4. Verificar links internos no index ──────────────────────────────────────
echo ""
echo "🔍 Verificando links quebrados no docs-site..."
BROKEN=0
while IFS= read -r link; do
  # Extrai o path do link markdown [text](/path)
  path=$(echo "$link" | sed 's|.*](/||' | sed 's|).*||' | sed 's|^/||')
  # Converte path para docs-site/docs/path.md (Rspress usa .md)
  target="docs-site/docs/${path}.md"
  target_index="docs-site/docs/${path}/index.md"
  if [ -f "$target" ] || [ -f "$target_index" ]; then
    continue
  fi
  echo "   ⚠  Link quebrado: ${path}"
  BROKEN=$((BROKEN + 1))
done < <(grep -oE '\]\(/[^)]+\)' docs-site/docs/index.md 2>/dev/null || true)

if [ "$BROKEN" -eq 0 ]; then
  echo -e "${GREEN}   ✓ Todos os links do index resolvem${NC}"
else
  echo -e "${RED}   ✗ ${BROKEN} link(s) quebrado(s) no index${NC}"
  ERRORS=$((ERRORS + 1))
fi

# ── Resultado ─────────────────────────────────────────────────────────────────
echo ""
echo "═══════════════════════════════════════════════════════════════"
if [ "$ERRORS" -eq 0 ]; then
  echo -e "${GREEN}✅ Pipeline de docs saudável.${NC}"
  exit 0
else
  echo -e "${RED}❌ ${ERRORS} problema(s) na pipeline de docs!${NC}"
  echo ""
  echo "   Rode localmente: mise run docs   (regenera docs/gerado + docs-site/docs)"
  exit 1
fi
