#!/usr/bin/env bash
#MISE description="Verifica cobertura da biblioteca de componentes UI"
# =============================================================================
# check/ui-coverage — Auditoria de adoção dos componentes UI padronizados
# =============================================================================
# Detecta:
#   - Compostos Bits UI exportados mas não usados por nenhum consumidor
#   - Elementos nativos (<button>, <input>, <select>) com equivalente na lib
#   - Padrões de interação reimplementados (modais, tabs, tooltips, dropdowns)
#   - Utility classes legadas (.badge, .btn, .msg-erro)
#   - Hex colors hardcoded fora de tokens.css/app.css
#
# Modos:
#   --strict   Falha se hex colors > 0 (bloqueia CI)
#   --report   Apenas imprime relatório (default)
#
# Roda em CI e local via: mise run check:ui-coverage
# =============================================================================

set -uo pipefail

MODE="${1:---report}"

# Resolve o diretório do projeto (mise roda do workspace root)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
cd "$PROJECT_ROOT/web/src"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
NC='\033[0m'
EXIT_CODE=0

echo ""
echo -e "${BOLD}═══════════════════════════════════════════════════════${NC}"
echo -e "${BOLD}  UI Component Library Coverage Audit${NC}"
echo -e "${BOLD}═══════════════════════════════════════════════════════${NC}"
echo ""

# ── Versão Bits UI ───────────────────────────────────────────
echo -e "${BOLD}Versão Bits UI:${NC}"
echo ""
INSTALLED=$(cd "$PROJECT_ROOT/web" && node -p "require('./node_modules/bits-ui/package.json').version" 2>/dev/null || echo "?")
LATEST=$(cd "$PROJECT_ROOT/web" && npm view bits-ui version 2>/dev/null || echo "?")
if [ "$INSTALLED" = "$LATEST" ]; then
  printf "  ${GREEN}✓${NC}  bits-ui@%s (última versão)\n" "$INSTALLED"
else
  printf "  ${YELLOW}⚠${NC}  bits-ui@%s instalado → %s disponível (npm update bits-ui)\n" "$INSTALLED" "$LATEST"
fi
echo ""

# ── Hex colors (bloqueante em --strict) ─────────────────────
hex_count=$(grep -rn '#[0-9a-fA-F]\{6\}' --include='*.svelte' | grep -v 'node_modules' | grep -v 'tokens.css' | grep -v 'app.css' | wc -l | tr -d ' ')

if [ "$hex_count" -eq 0 ]; then
  echo -e "${GREEN}✓ ZERO hex colors hardcoded${NC}"
else
  echo -e "${RED}✗ $hex_count hex colors hardcoded (devem usar tokens CSS)${NC}"
  grep -rn '#[0-9a-fA-F]\{6\}' --include='*.svelte' | grep -v 'node_modules' | grep -v 'tokens.css' | grep -v 'app.css' | head -10 | while read line; do
    echo "  $line"
  done
  if [ "$MODE" = "--strict" ]; then
    EXIT_CODE=1
  fi
fi
echo ""

# ── Compostos Bits UI não adotados ──────────────────────────
echo -e "${BOLD}Compostos Bits UI — Adoção:${NC}"
echo ""
for comp in Dialog DropdownMenu Select Tabs Tooltip; do
  count=$(grep -rl "$comp" --include="*.svelte" | grep -v node_modules | grep -v 'components/ui/' | xargs grep -l "from.*components/ui" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$count" -eq 0 ]; then
    printf "  ${YELLOW}⚠${NC}  %-14s → 0 consumidores\n" "$comp"
  else
    printf "  ${GREEN}✓${NC}  %-14s → %s consumidores\n" "$comp" "$count"
  fi
done
echo ""

# ── Elementos nativos com equivalente ───────────────────────
echo -e "${BOLD}Elementos nativos com equivalente UI:${NC}"
echo ""

btn_count=$(grep -r '<button' --include='*.svelte' | grep -v node_modules | grep -v 'components/ui/Button' | grep -v 'components/ui/Tabs' | grep -v 'components/ui/DropdownMenu' | grep -v 'components/ui/Dialog' | wc -l | tr -d ' ')
input_count=$(grep -r '<input' --include='*.svelte' | grep -v node_modules | grep -v 'components/ui/Input' | wc -l | tr -d ' ')
select_count=$(grep -r '<select' --include='*.svelte' | grep -v node_modules | grep -v 'components/ui/Select' | wc -l | tr -d ' ')

printf "  <button> inline:  %s\n" "$btn_count"
printf "  <input> inline:   %s\n" "$input_count"
printf "  <select> nativo:  %s\n" "$select_count"
echo ""

# ── Utility classes legadas ─────────────────────────────────
echo -e "${BOLD}Utility classes legadas:${NC}"
echo ""

badge_count=$(grep -r 'class.*badge' --include='*.svelte' | grep -v node_modules | grep -v 'components/ui/' | wc -l | tr -d ' ')
msg_count=$(grep -r 'class.*msg-' --include='*.svelte' | grep -v node_modules | grep -v 'components/ui/' | wc -l | tr -d ' ')
btn_class=$(grep -r 'class.*btn' --include='*.svelte' | grep -v node_modules | grep -v 'components/ui/' | wc -l | tr -d ' ')

printf "  .badge:           %s\n" "$badge_count"
printf "  .msg-erro/sucesso: %s\n" "$msg_count"
printf "  .btn class:       %s\n" "$btn_class"
echo ""

# ── Resumo ──────────────────────────────────────────────────
total_native=$((btn_count + input_count + select_count))
total_legacy=$((badge_count + msg_count + btn_class))

echo -e "${BOLD}── RESUMO ──${NC}"
echo ""
echo "  Elementos nativos com equivalente:  $total_native"
echo "  Utility classes legadas:            $total_legacy"
echo "  Hex colors hardcoded:               $hex_count"
echo ""

if [ "$EXIT_CODE" -ne 0 ]; then
  echo -e "${RED}❌ Falha: hex colors hardcoded detectados (modo --strict)${NC}"
fi

exit $EXIT_CODE
