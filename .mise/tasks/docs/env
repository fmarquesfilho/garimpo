#!/usr/bin/env bash
#MISE description="Extrai variáveis de ambiente do código → docs/gerado/env-vars.md"
# Gera docs/gerado/env-vars.md a partir das referências no código Go.

set -euo pipefail

OUTPUT="docs/gerado/env-vars.md"
# docs/gerado/ é gitignored (não existe em checkout limpo do CI).
mkdir -p "$(dirname "$OUTPUT")"

{
cat <<'HEADER'
---
title: Variáveis de ambiente
description: Lista de variáveis de ambiente extraídas do código-fonte.
---

:::caution[Arquivo gerado]
Não edite manualmente. Rode `mise run docs:env` para regenerar.
:::

| Variável | Arquivo | Linha |
|---|---|---|
HEADER

# Busca por os.Getenv("...") e os.LookupEnv("...") nos fontes Go
grep -rn "os\.Getenv\|os\.LookupEnv" . \
  --include="*.go" \
  --exclude-dir=vendor \
  --exclude-dir=.git \
  | sed "s|^\./||" \
  | while IFS='' read -r match; do
      file="${match%%:*}"
      rest="${match#*:}"
      line="${rest%%:*}"
      var=$(echo "$match" | sed -n 's/.*Getenv("\([^"]*\)".*/\1/p')
      if [ -z "$var" ]; then
        var=$(echo "$match" | sed -n 's/.*LookupEnv("\([^"]*\)".*/\1/p')
      fi
      if [ -n "$var" ]; then
        echo "| \`$var\` | \`$file\` | $line |"
      fi
    done \
  | sort -t'|' -k2,2 -k3,3 \
  | awk -F'|' '!seen[$2]++'
} > "$OUTPUT"

echo "✓ $OUTPUT gerado" 
