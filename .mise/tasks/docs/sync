#!/usr/bin/env bash
#MISE description="Sincroniza docs canônicos para docs-site"
# =============================================================================
# sync-docs-to-site.sh — Sincroniza docs/ para docs-site/docs/ (Rspress)
# =============================================================================
# Copia e adapta os Markdown do docs/ para o formato esperado pelo Rspress:
# - Remove prefixo numérico dos arquivos (01-visao → visao)
# - Copia TODOS os ADRs para decisoes/
# - Corrige links internos (/docs/decisoes/X → /decisoes/X)
# =============================================================================

set -euo pipefail

DEST="docs-site/docs"
rm -rf "$DEST"
mkdir -p "$DEST/decisoes" "$DEST/public"

# ── Favicon ───────────────────────────────────────────────────────────────────
cp web/static/favicon.svg "$DEST/public/favicon.svg" 2>/dev/null || true

# ── Docs principais (remove prefixo numérico) ────────────────────────────────
cp docs/01-visao-e-negocio.md "$DEST/visao-e-negocio.md"
cp docs/02-arquitetura.md "$DEST/arquitetura.md"
cp docs/03-fluxos-e-modelo.md "$DEST/fluxos-e-modelo.md"
cp docs/04-operacao-shopee.md "$DEST/operacao-shopee.md"
cp docs/05-manual-do-usuario.md "$DEST/manual-do-usuario.md"
cp docs/06-qualidade-e-testes.md "$DEST/qualidade-e-testes.md"
cp docs/07-dados-e-ia.md "$DEST/dados-e-ia.md"
cp docs/08-fluxos-sequencia.md "$DEST/fluxos-sequencia.md"

# ── TODOS os ADRs ────────────────────────────────────────────────────────────
for adr in docs/decisoes/*.md; do
  [ -f "$adr" ] && cp "$adr" "$DEST/decisoes/"
done

# ── Docs de frontend (componentes, impacto) ──────────────────────────────────
mkdir -p "$DEST/frontend"
cp docs/componentes.md "$DEST/frontend/componentes.md"
cp docs/impacto-migracao-ui.md "$DEST/frontend/impacto-migracao-ui.md"

# ── Docs de observabilidade ───────────────────────────────────────────────────
cp docs/observability.md "$DEST/observability.md"

# ── Docs gerados (board, roadmap, entidades, env) ────────────────────────────
mkdir -p "$DEST/gerado"
for f in docs/gerado/*.md; do
  [ -f "$f" ] && cp "$f" "$DEST/gerado/"
done

# ── Guias ─────────────────────────────────────────────────────────────────────
if [ -d "docs/guias" ] && [ "$(ls docs/guias/*.md 2>/dev/null)" ]; then
  mkdir -p "$DEST/guias"
  for f in docs/guias/*.md; do
    [ -f "$f" ] && cp "$f" "$DEST/guias/"
  done
fi

# ── Sessões de desenvolvimento (legado) ───────────────────────────────────────
if [ -d "docs/legado" ] && [ "$(ls docs/legado/*.md 2>/dev/null)" ]; then
  mkdir -p "$DEST/sessoes"
  for f in docs/legado/*.md; do
    [ -f "$f" ] && cp "$f" "$DEST/sessoes/"
  done
fi

# ── Sprint atual (backlog) ────────────────────────────────────────────────────
if [ -f "backlog/sprint.txt" ]; then
  mkdir -p "$DEST/projeto"
  {
    echo "# Sprint Atual"
    echo ""
    echo "> Gerado a partir de \`backlog/sprint.txt\`"
    echo ""
    SPRINT_ID=$(head -1 backlog/sprint.txt)
    echo "**Sprint:** $SPRINT_ID"
    echo ""
    echo "## Tasks da Sprint"
    echo ""
    tail -n +2 backlog/sprint.txt | while read -r task_id; do
      [ -z "$task_id" ] && continue
      TASK_FILE="backlog/tasks/${task_id}-*.yaml"
      # shellcheck disable=SC2086
      if ls $TASK_FILE 1>/dev/null 2>&1; then
        TITULO=$(grep "^titulo:" $TASK_FILE | head -1 | sed 's/titulo: *"//' | sed 's/"$//')
        STATUS=$(grep "^status:" $TASK_FILE | head -1 | sed 's/status: *//')
        echo "- [**${task_id}**](/tarefas/${task_id}) — ${TITULO} (\`${STATUS}\`)"
      else
        echo "- **${task_id}**"
      fi
    done
  } > "$DEST/projeto/sprint.md"
fi

# ── Tarefas do backlog → páginas individuais ──────────────────────────────────
mkdir -p "$DEST/tarefas"
for f in backlog/tasks/*.yaml; do
  [ -f "$f" ] || continue
  TASK_ID=$(grep "^id:" "$f" | head -1 | sed 's/id: *//' || true)
  TITULO=$(grep "^titulo:" "$f" | head -1 | sed 's/titulo: *"//' | sed 's/"$//' || true)
  STATUS=$(grep "^status:" "$f" | head -1 | sed 's/status: *//' || true)
  PRIORIDADE=$(grep "^prioridade:" "$f" | head -1 | sed 's/prioridade: *//' || true)
  ESTIMATIVA=$(grep "^estimativa:" "$f" | head -1 | sed 's/estimativa: *//' || true)
  SPRINT=$(grep "^sprint:" "$f" | head -1 | sed 's/sprint: *"//' | sed 's/"$//' || true)
  TAGS=$(grep "^tags:" "$f" | head -1 | sed 's/tags: *//' || true)

  {
    echo "# ${TASK_ID}: ${TITULO}"
    echo ""
    echo "| Campo | Valor |"
    echo "|-------|-------|"
    echo "| Status | \`${STATUS}\` |"
    echo "| Prioridade | ${PRIORIDADE} |"
    echo "| Estimativa | ${ESTIMATIVA} |"
    echo "| Sprint | ${SPRINT:-—} |"
    echo "| Tags | ${TAGS} |"
    echo ""
    echo "## Descrição"
    echo ""
    # Extract multi-line fields (valor, descricao, criterios)
    sed -n '/^valor:/,/^[a-z]/{ /^valor:/d; /^[a-z]/d; p; }' "$f" | sed 's/^  //'
    echo ""
    echo "## Critérios de aceite"
    echo ""
    sed -n '/^criterios:/,/^[a-z]/{ /^criterios:/d; /^[a-z]/d; p; }' "$f" | sed 's/^  - /- ✅ /'
  } > "$DEST/tarefas/${TASK_ID}.md"
done
echo "✓ $(ls "$DEST/tarefas/" | wc -l | tr -d ' ') tarefas geradas"

# ── Index page ────────────────────────────────────────────────────────────────
cat > "$DEST/index.md" << 'EOF'
---
pageType: home
hero:
  name: Garimpei
  text: Documentação Técnica
  tagline: Curadoria inteligente para afiliados — arquitetura, decisões, e guias.
  actions:
    - theme: brand
      text: Arquitetura
      link: /arquitetura
    - theme: alt
      text: Componentes UI
      link: /frontend/componentes
---

## Navegação Rápida

### Produto

- [Visão e Negócio](/visao-e-negocio) — O quê e pra quem
- [Arquitetura](/arquitetura) — Cloud Run, gRPC, BigQuery, Cloudflare
- [Fluxos e Modelo](/fluxos-e-modelo) — Entidades e regras de negócio
- [Operação Shopee](/operacao-shopee) — Integração com API de afiliados
- [Manual do Usuário](/manual-do-usuario) — Como usar o app

### Frontend

- [Componentes UI](/frontend/componentes) — shadcn-svelte + Tailwind + Bits UI
- [Impacto da Migração](/frontend/impacto-migracao-ui) — Métricas e dívida técnica

### Observabilidade

- [OpenTelemetry & Logs](/observability) — Traces distribuídos, Cloud Trace, Cloud Logging

### Projeto

- [Roadmap](/gerado/ROADMAP) — Now / Next / Later
- [Quadro Kanban](/gerado/BOARD) — Sprint atual
- [Entidades (ER)](/gerado/ENTIDADES) — Schema BigQuery
- [Variáveis de Ambiente](/gerado/env-vars) — Configs dos serviços

### Referência

- [22 Decisões Arquiteturais (ADRs)](/decisoes/0012-migracao-csharp-go-microservices)
- [API Reference (OpenAPI 3.1)](/api)
- [Guia: Desenvolvimento Local](/guias/desenvolvimento-local)
- [Guia: WhatsApp Meta](/guias/configurar-whatsapp-meta)
- [Sessões de Desenvolvimento](/sessoes/SESSAO_2026-07-03_SHADCN_MIGRATION)
EOF

# ── API page (copiada de docs/09-api-reference.md)
cp "docs/09-api-reference.md" "$DEST/api.md"

# ── Corrigir links internos ───────────────────────────────────────────────────
# sed -i portável (macOS BSD sed vs GNU sed)
sedi() {
  if [[ "$OSTYPE" == "darwin"* ]]; then
    sed -i '' "$@"
  else
    sed -i "$@"
  fi
}

for f in "$DEST"/*.md "$DEST"/decisoes/*.md "$DEST"/frontend/*.md "$DEST"/gerado/*.md "$DEST"/guias/*.md "$DEST"/projeto/*.md; do
  [ -f "$f" ] || continue
  sedi 's|(/docs/decisoes/\([^/)]*\)/)|(/decisoes/\1)|g' "$f"
  sedi 's|(/docs/decisoes/\([^)]*\))|(/decisoes/\1)|g' "$f"
  sedi 's|(/docs/\([^/)]*\)/)|(/\1)|g' "$f"
  sedi 's|(/docs/\([^)]*\))|(/\1)|g' "$f"
done

echo "✓ Docs sincronizados para $DEST ($(ls "$DEST"/decisoes/ | wc -l | tr -d ' ') ADRs)"

# ── Gerar _sidebar.json (consumido pelo rspress.config.ts) ───────────────────
# Gera sidebar completo a partir do filesystem — qualquer novo .md aparece automaticamente.

generate_sidebar() {
  local dest="$1"
  local json="$dest/_sidebar.json"

  # Helper: lista .md de um diretório como items JSON
  dir_items() {
    local dir="$1"
    local prefix="$2"
    local first=true
    for f in "$dir"/*.md; do
      [ -f "$f" ] || continue
      local basename=$(basename "$f" .md)
      [ "$basename" = "index" ] && continue
      # Extract title: frontmatter title > first heading > filename
      local title=""
      if head -1 "$f" | grep -q "^---"; then
        title=$(grep "^title:" "$f" | head -1 | sed 's/^title: *//' | sed 's/"/\\"/g')
      fi
      if [ -z "$title" ]; then
        title=$(grep "^#" "$f" | head -1 | sed 's/^#* *//' | sed 's/"/\\"/g')
      fi
      [ -z "$title" ] && title="$basename"
      $first || printf ","
      first=false
      printf '{"text":"%s","link":"/%s/%s"}' "$title" "$prefix" "$basename"
    done
  }

  cat > "$json" << ENDJSON
[
  {"text":"Visão Geral","items":[
    {"text":"Introdução","link":"/"},
    {"text":"Visão e Negócio","link":"/visao-e-negocio"}
  ]},
  {"text":"Arquitetura","items":[
    {"text":"Visão Geral","link":"/arquitetura"},
    {"text":"Fluxos e Modelo","link":"/fluxos-e-modelo"},
    {"text":"Fluxos de Sequência","link":"/fluxos-sequencia"},
    {"text":"Operação Shopee","link":"/operacao-shopee"}
  ]},
  {"text":"Operação","items":[
    {"text":"Manual do Usuário","link":"/manual-do-usuario"},
    {"text":"Qualidade e Testes","link":"/qualidade-e-testes"},
    {"text":"Dados e IA","link":"/dados-e-ia"}
  ]},
ENDJSON

  # Frontend (dinâmico)
  printf '  {"text":"Frontend","items":[' >> "$json"
  dir_items "$dest/frontend" "frontend" >> "$json"
  printf ']},\n' >> "$json"

  # Projeto (dinâmico)
  printf '  {"text":"Projeto","items":[' >> "$json"
  local proj_first=true
  for f in "$dest/gerado"/*.md; do
    [ -f "$f" ] || continue
    local bn=$(basename "$f" .md)
    local t=""
    if head -1 "$f" | grep -q "^---"; then
      t=$(grep "^title:" "$f" | head -1 | sed 's/^title: *//' | sed 's/"/\\"/g')
    fi
    if [ -z "$t" ]; then
      t=$(grep "^#" "$f" | head -1 | sed 's/^#* *//' | sed 's/"/\\"/g')
    fi
    [ -z "$t" ] && t="$bn"
    $proj_first || printf "," >> "$json"
    proj_first=false
    printf '{"text":"%s","link":"/gerado/%s"}' "$t" "$bn" >> "$json"
  done
  if [ -f "$dest/projeto/sprint.md" ]; then
    printf ',{"text":"Sprint Atual","link":"/projeto/sprint"}' >> "$json"
  fi
  printf ']},\n' >> "$json"

  # ADRs (dinâmico)
  printf '  {"text":"Decisões (ADRs)","items":[' >> "$json"
  local adr_first=true
  for f in "$dest/decisoes"/*.md; do
    [ -f "$f" ] || continue
    local bn=$(basename "$f" .md)
    local num=$(echo "$bn" | cut -d- -f1)
    local slug=$(echo "$bn" | sed 's/^[0-9]*-//' | sed 's/-/ /g')
    local cap=$(echo "$slug" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')
    $adr_first || printf "," >> "$json"
    adr_first=false
    printf '{"text":"%s: %s","link":"/decisoes/%s"}' "$num" "$cap" "$bn" >> "$json"
  done
  printf ']},\n' >> "$json"

  # Guias (dinâmico)
  if [ -d "$dest/guias" ]; then
    printf '  {"text":"Guias","items":[' >> "$json"
    dir_items "$dest/guias" "guias" >> "$json"
    printf ']},\n' >> "$json"
  fi

  # Sessões de desenvolvimento (dinâmico)
  if [ -d "$dest/sessoes" ]; then
    printf '  {"text":"Sessões","items":[' >> "$json"
    dir_items "$dest/sessoes" "sessoes" >> "$json"
    printf ']},\n' >> "$json"
  fi

  # Tarefas (dinâmico — gerado do backlog)
  if [ -d "$dest/tarefas" ] && [ "$(ls "$dest/tarefas/"*.md 2>/dev/null)" ]; then
    printf '  {"text":"Tarefas","items":[' >> "$json"
    printf '{"text":"📋 Todas as Tarefas","link":"/gerado/TAREFAS"},' >> "$json"
    dir_items "$dest/tarefas" "tarefas" >> "$json"
    printf ']},\n' >> "$json"
  fi

  # API (fixo)
  printf '  {"text":"API","items":[{"text":"OpenAPI Spec","link":"/api"}]}\n' >> "$json"
  printf ']\n' >> "$json"
}

generate_sidebar "$DEST"
echo "✓ _sidebar.json gerado"
