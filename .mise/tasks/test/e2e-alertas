#!/usr/bin/env bash
# mise description="E2E Alertas: detecção de quedas/novidades → Cloud Tasks → Publisher → Telegram"
set -euo pipefail

# shellcheck source=.mise/tasks/test/e2e-lib
source "$(dirname "$0")/e2e-lib"

echo "═══════════════════════════════════════════════"
echo "  🔔 E2E Alertas Cross-Service"
echo "═══════════════════════════════════════════════"
echo ""
echo "  Fluxo validado:"
echo "    1. Analyzer /quedas — detecção de variação de preço (BigQuery)"
echo "    2. Analyzer /novidades — detecção de produtos novos (BigQuery)"
echo "    3. Alertas config — verificar threshold configurado"
echo "    4. Simular process-alert (Scheduler → Analyzer → Publisher)"
echo "    5. Verificar Publisher responde (Telegram/WhatsApp)"
echo "    6. Verificar isolamento multi-tenant"
echo ""
echo "  Cada step gera traceparent → rastreável no Cloud Trace"
echo ""

e2e_auth

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 1. Detecção de quedas (Analyzer → BigQuery) "
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "analyzer-quedas"
echo "     traceparent: $E2E_LAST_TRACEPARENT"

# Usa o proxy correto: /api/v2/curadoria/quedas (C# → Analyzer HTTP)
QUEDAS_DIRECT=$(e2e_get "/api/v2/curadoria/quedas?dias=7&threshold=0.15&limit=10" "$E2E_LAST_TRACEPARENT")

if echo "$QUEDAS_DIRECT" | grep -q '"quedas"'; then
  QUEDAS_COUNT=$(echo "$QUEDAS_DIRECT" | jq '.total // (.quedas | length) // 0' 2>/dev/null || echo "0")
  e2e_ok "Analyzer /quedas via proxy ($QUEDAS_COUNT quedas detectadas)"

  if [ "$QUEDAS_COUNT" -gt 0 ]; then
    # Verifica estrutura da queda
    QUEDA_ITEM=$(echo "$QUEDAS_DIRECT" | jq '.quedas[0]' 2>/dev/null)
    if echo "$QUEDA_ITEM" | jq -e '.produto_id, .nome, .preco_anterior, .preco_atual, .variacao' > /dev/null 2>&1; then
      e2e_ok "Queda tem campos obrigatórios (produto_id, nome, precos, variacao)"
      VARIACAO=$(echo "$QUEDA_ITEM" | jq '.variacao' 2>/dev/null)
      NOME_QUEDA=$(echo "$QUEDA_ITEM" | jq -r '.nome' 2>/dev/null)
      echo "     Maior queda: $VARIACAO ($NOME_QUEDA)"
    else
      e2e_fail "Queda com campos incompletos" "$(echo "$QUEDA_ITEM" | head -c 200)"
    fi
  else
    e2e_ok "Nenhuma queda na janela (threshold=15%, 7 dias — dados estáveis)"
  fi
else
  e2e_fail "Proxy /api/v2/curadoria/quedas indisponível" "$(echo "$QUEDAS_DIRECT" | head -c 200)"
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 2. Detecção de novidades (Analyzer → BQ) ──"
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "analyzer-novidades"
echo "     traceparent: $E2E_LAST_TRACEPARENT"

# Usa oportunidades/agora que já agrega novidades + quedas + alto-valor
OPORT_RESP=$(e2e_get "/api/oportunidades/agora?dias=7" "$E2E_LAST_TRACEPARENT")

if echo "$OPORT_RESP" | grep -q '"novos"\|"total_novos"'; then
  NOVOS=$(echo "$OPORT_RESP" | jq '.total_novos // 0' 2>/dev/null || echo "0")
  QUEDAS_OPT=$(echo "$OPORT_RESP" | jq '.total_quedas // 0' 2>/dev/null || echo "0")
  e2e_ok "Oportunidades: $NOVOS novos, $QUEDAS_OPT quedas (via /oportunidades/agora)"
else
  e2e_fail "Endpoint /api/oportunidades/agora falhou" "$(echo "$OPORT_RESP" | head -c 200)"
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 3. Configuração de alertas ────────────────"
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "alertas-config"

ALERTAS_RESP=$(e2e_get "/api/alertas" "$E2E_LAST_TRACEPARENT")

if echo "$ALERTAS_RESP" | grep -q '"threshold"'; then
  THRESHOLD=$(echo "$ALERTAS_RESP" | jq '.threshold // 0' 2>/dev/null || echo "0")
  HABILITADO=$(echo "$ALERTAS_RESP" | jq '.habilitado // false' 2>/dev/null)
  e2e_ok "Config alertas: threshold=$THRESHOLD, habilitado=$HABILITADO"

  if [ "$HABILITADO" = "true" ]; then
    e2e_ok "Alertas habilitados (Cloud Tasks vai disparar)"
  else
    # Habilitar alertas para o tenant E2E (precisa de chat_id configurado)
    echo "     Alertas desabilitados — configurando chat_id E2E..."
    CONFIG_RESP=$(e2e_post "/api/alertas/configurar" \
      '{"ChatId":"e2e-test-chat","Threshold":0.15}' \
      "$E2E_LAST_TRACEPARENT")

    if echo "$CONFIG_RESP" | grep -q '"configurado"'; then
      e2e_ok "Alertas configurados para tenant E2E (chat_id: e2e-test-chat)"
    else
      e2e_fail "Falha ao configurar alertas" "$(echo "$CONFIG_RESP" | head -c 200)"
    fi
  fi
else
  e2e_fail "GET /api/alertas falhou" "$(echo "$ALERTAS_RESP" | head -c 200)"
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 4. Simular alerta (process-alert flow) ────"
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "process-alert-simulation"
echo "     traceparent: $E2E_LAST_TRACEPARENT"
echo ""
echo "     Fluxo real: Cloud Tasks → Scheduler POST /process-alert"
echo "     → Analyzer GET /quedas → Publisher gRPC Publish → Telegram"
echo ""

# Não podemos chamar /process-alert diretamente (é internal endpoint do scheduler,
# protegido por OIDC no Cloud Tasks). Verificamos os componentes individuais.

# 4a. Verificar que o Analyzer responde com dados
echo "     4a. Analyzer disponível para consulta de quedas"
ANALYZER_CHECK=$(e2e_get "/api/coletas?dias=2" "$E2E_LAST_TRACEPARENT")
if echo "$ANALYZER_CHECK" | grep -q '"coletas"'; then
  e2e_ok "Analyzer responde (dados para detecção de alertas)"
else
  e2e_fail "Analyzer indisponível (process-alert falharia)" "$(echo "$ANALYZER_CHECK" | head -c 200)"
fi

# 4b. Verificar stack health (inclui publisher implicitamente)
echo "     4b. Stack health (publisher implicitamente ativo)"
e2e_new_trace "stack-health"
HEALTH_RESP=$(e2e_get "/api/health" "$E2E_LAST_TRACEPARENT")
if echo "$HEALTH_RESP" | grep -q '"status"'; then
  e2e_ok "Stack health OK (publisher ativo dentro do multi-container)"
else
  e2e_fail "Health check falhou" "$(echo "$HEALTH_RESP" | head -c 200)"
fi

# 4c. Verificar publicações existentes (prova que Publisher funciona)
echo "     4c. Publisher → Telegram: publicações recentes"
e2e_new_trace "publisher-check"
PUB_RESP=$(e2e_get "/api/publicacoes" "$E2E_LAST_TRACEPARENT")
if echo "$PUB_RESP" | grep -q '"publicacoes"'; then
  PUB_COUNT=$(echo "$PUB_RESP" | jq '.publicacoes | length' 2>/dev/null || echo "0")
  e2e_ok "Publisher ativo ($PUB_COUNT publicações registradas)"
else
  e2e_warn "Sem publicações registradas" "Normal se nenhuma publicação foi feita recentemente"
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 5. Testar envio de alerta (dry-run) ───────"
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "alert-dry-run"
echo "     traceparent: $E2E_LAST_TRACEPARENT"

# Usa o endpoint correto: POST /api/alertas/testar
# Nota: curl sem -f pois 400 é resposta válida (bot não configurado)
DRYRUN_RESP=$(curl -s -X POST \
  -H "Authorization: Bearer $E2E_TOKEN" \
  -H "Content-Type: application/json" \
  -H "traceparent: $E2E_LAST_TRACEPARENT" \
  -d '{}' \
  "${E2E_BASE}/api/alertas/testar" 2>/dev/null || echo "CURL_FAIL")

if echo "$DRYRUN_RESP" | grep -q '"status":"enviado"'; then
  e2e_ok "Alerta de teste enviado com sucesso"
  CHAT_ID=$(echo "$DRYRUN_RESP" | jq -r '.chat_id // "(sem id)"' 2>/dev/null)
  echo "     chat_id: $CHAT_ID"
elif echo "$DRYRUN_RESP" | grep -q '"error"'; then
  # 400 esperado: endpoint funciona mas bot token não configurado para tenant E2E
  DETAIL=$(echo "$DRYRUN_RESP" | jq -r '.detail // .error // "?"' 2>/dev/null)
  e2e_ok "POST /api/alertas/testar funciona (sem bot real: $DETAIL)"
else
  e2e_fail "POST /api/alertas/testar falhou" "$(echo "$DRYRUN_RESP" | head -c 200)"
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 6. Isolamento multi-tenant (alertas) ──────"
# ──────────────────────────────────────────────────────────────────────────────

# Alertas são scoped por owner_uid (EF Core global filter)
e2e_assert_no_leak "/api/alertas" "threshold" "GET /api/alertas requer auth"
e2e_assert_no_leak "/api/coletas" "coletas" "GET /api/coletas requer auth"
e2e_assert_no_leak "/api/publicacoes" "publicacoes" "GET /api/publicacoes requer auth"

echo ""
echo "  🔒 Isolamento garantido por:"
echo "     • EF Core query filter (PostgreSQL): owner_uid = current_user"
echo "     • BigQuery: WHERE owner_uid = @uid em todas as queries"
echo "     • Cloud Tasks: payload carrega owner_uid, validado no processamento"

# ──────────────────────────────────────────────────────────────────────────────
e2e_summary "E2E Alertas Cross-Service"
