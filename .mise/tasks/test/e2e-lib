#!/usr/bin/env bash
# mise hide=true
# mise description="Biblioteca compartilhada para testes E2E cross-service (não executar diretamente)"
# shellcheck disable=SC2034
# ──────────────────────────────────────────────────────────────────────────────
# Funções utilitárias para testes E2E com OTel traceparent.
# Usar via: source .mise/tasks/test/e2e-lib
# ──────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# ─── Cores ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ─── Contadores ──────────────────────────────────────────────────────────────
E2E_PASS=0
E2E_FAIL=0
E2E_WARN=0
declare -a E2E_TRACE_IDS=()

# ─── Auth ─────────────────────────────────────────────────────────────────────

e2e_auth() {
  cd web 2>/dev/null || true
  source .env.e2e.local 2>/dev/null || source .env.e2e 2>/dev/null || true
  cd - > /dev/null 2>/dev/null || true

  if [ -z "${E2E_PASSWORD:-}" ]; then
    echo -e "${RED}❌ E2E_PASSWORD vazio. Copie web/.env.e2e → web/.env.e2e.local${NC}"
    exit 1
  fi

  E2E_TOKEN_RESP=$(curl -s "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=AIzaSyA5sBUoVkNHiq58KUkmwbxIMLhvgTn7N8A" \
    -H "Content-Type: application/json" \
    -d "{\"email\":\"${E2E_EMAIL}\",\"password\":\"${E2E_PASSWORD}\",\"returnSecureToken\":true}")

  E2E_TOKEN=$(echo "$E2E_TOKEN_RESP" | jq -r '.idToken // empty')
  if [ -z "$E2E_TOKEN" ]; then
    echo -e "${RED}❌ Auth falhou:${NC}"
    echo "$E2E_TOKEN_RESP" | jq .
    exit 1
  fi

  E2E_UID=$(echo "$E2E_TOKEN_RESP" | jq -r '.localId // empty')
  E2E_BASE="${E2E_BASE_URL:-https://garimpei.app.br}"
  echo -e "  ${GREEN}✅${NC} Autenticado como ${E2E_EMAIL} (uid: ${E2E_UID:0:8}...)"
}

# ─── OTel Traceparent ─────────────────────────────────────────────────────────

# Gera um traceparent W3C válido com trace_id determinístico para rastreio.
# Armazena em E2E_LAST_TRACEPARENT e registra o trace_id no array.
# Usage: e2e_traceparent "nome-do-teste"
#        TRACEPARENT="$E2E_LAST_TRACEPARENT"
e2e_traceparent() {
  local test_name="${1:-test}"
  local trace_id span_id

  trace_id=$(python3 -c "import uuid; print(uuid.uuid4().hex)")
  span_id=$(python3 -c "import os; print(os.urandom(8).hex())")
  E2E_LAST_TRACEPARENT="00-${trace_id}-${span_id}-01"

  E2E_TRACE_IDS+=("$trace_id|$test_name")
  echo "$E2E_LAST_TRACEPARENT"
}

# Variante que não usa subshell — seta E2E_LAST_TRACEPARENT e registra trace
e2e_new_trace() {
  local test_name="${1:-test}"
  local trace_id span_id

  trace_id=$(python3 -c "import uuid; print(uuid.uuid4().hex)")
  span_id=$(python3 -c "import os; print(os.urandom(8).hex())")
  E2E_LAST_TRACEPARENT="00-${trace_id}-${span_id}-01"
  E2E_LAST_TRACE_ID="$trace_id"

  E2E_TRACE_IDS+=("$trace_id|$test_name")
}

# Extrai o trace_id de um traceparent
e2e_trace_id() {
  local traceparent="$1"
  echo "$traceparent" | cut -d'-' -f2
}

# ─── HTTP helpers ─────────────────────────────────────────────────────────────

# GET autenticado com traceparent
# Usage: RESP=$(e2e_get "/api/buscas" "$TRACEPARENT")
e2e_get() {
  local endpoint="$1"
  local traceparent="${2:-}"
  local headers=(-H "Authorization: Bearer $E2E_TOKEN")

  if [ -n "$traceparent" ]; then
    headers+=(-H "traceparent: $traceparent")
  fi

  curl -sf "${headers[@]}" "${E2E_BASE}${endpoint}" 2>/dev/null || echo "CURL_FAIL"
}

# POST autenticado com traceparent
# Usage: RESP=$(e2e_post "/api/buscas" '{"keywords":["test"]}' "$TRACEPARENT")
e2e_post() {
  local endpoint="$1"
  local body="$2"
  local traceparent="${3:-}"
  local headers=(-H "Authorization: Bearer $E2E_TOKEN" -H "Content-Type: application/json")

  if [ -n "$traceparent" ]; then
    headers+=(-H "traceparent: $traceparent")
  fi

  curl -sf -X POST "${headers[@]}" -d "$body" "${E2E_BASE}${endpoint}" 2>/dev/null || echo "CURL_FAIL"
}

# DELETE autenticado com traceparent
e2e_delete() {
  local endpoint="$1"
  local traceparent="${2:-}"
  local headers=(-H "Authorization: Bearer $E2E_TOKEN")

  if [ -n "$traceparent" ]; then
    headers+=(-H "traceparent: $traceparent")
  fi

  curl -sf -X DELETE "${headers[@]}" "${E2E_BASE}${endpoint}" 2>/dev/null || echo "CURL_FAIL"
}

# ─── Assertions ───────────────────────────────────────────────────────────────

e2e_ok() {
  echo -e "  ${GREEN}✅${NC} $1"
  E2E_PASS=$((E2E_PASS + 1))
}

e2e_fail() {
  echo -e "  ${RED}❌${NC} $1"
  if [ -n "${2:-}" ]; then
    echo -e "     ${RED}$2${NC}"
  fi
  E2E_FAIL=$((E2E_FAIL + 1))
}

e2e_warn() {
  echo -e "  ${YELLOW}⚠️${NC}  $1"
  if [ -n "${2:-}" ]; then
    echo -e "     ${YELLOW}$2${NC}"
  fi
  E2E_WARN=$((E2E_WARN + 1))
}

# assert_contains RESP EXPECTED DESCRIPTION
e2e_assert_contains() {
  local resp="$1" expected="$2" desc="$3"
  if echo "$resp" | grep -q "$expected"; then
    e2e_ok "$desc"
  else
    e2e_fail "$desc" "Expected: $expected | Got: $(echo "$resp" | head -c 200)"
  fi
}

# assert_json_field RESP FIELD DESCRIPTION
e2e_assert_json_field() {
  local resp="$1" field="$2" desc="$3"
  if echo "$resp" | jq -e ".$field" > /dev/null 2>&1; then
    e2e_ok "$desc"
  else
    e2e_fail "$desc" "Campo .$field não encontrado na resposta"
  fi
}

# assert_json_gt RESP EXPR DESCRIPTION (jq expression returns number > 0)
e2e_assert_json_gt() {
  local resp="$1" expr="$2" desc="$3"
  local val
  val=$(echo "$resp" | jq "$expr" 2>/dev/null || echo "0")
  if [ "$val" != "null" ] && [ "$val" != "0" ] && [ "$val" != "" ]; then
    e2e_ok "$desc (=$val)"
  else
    e2e_fail "$desc" "Valor: $val (esperado > 0)"
  fi
}

# ─── Multi-tenant isolation check ────────────────────────────────────────────

# Verifica que dados do e2e não vazam para outro tenant (sem auth)
e2e_assert_no_leak() {
  local endpoint="$1" field="$2" desc="$3"
  local resp
  resp=$(curl -sf "${E2E_BASE}${endpoint}" 2>/dev/null || echo "CURL_FAIL")

  if echo "$resp" | grep -q "401\|Unauthorized\|CURL_FAIL"; then
    e2e_ok "$desc (endpoint protegido por auth)"
  else
    e2e_fail "$desc" "Endpoint acessível sem auth!"
  fi
}

# ─── Summary ──────────────────────────────────────────────────────────────────

e2e_summary() {
  local test_name="${1:-E2E}"
  echo ""
  echo "═══════════════════════════════════════════════"
  echo -e "  ${CYAN}📊 Resultado: $test_name${NC}"
  echo "═══════════════════════════════════════════════"
  echo -e "  Passed: ${GREEN}$E2E_PASS${NC}"
  echo -e "  Failed: ${RED}$E2E_FAIL${NC}"
  if [ "$E2E_WARN" -gt 0 ]; then
    echo -e "  Warnings: ${YELLOW}$E2E_WARN${NC}"
  fi

  if [ "${#E2E_TRACE_IDS[@]}" -gt 0 ]; then
    echo ""
    echo "  🔭 Traces gerados (para debug via Cloud Trace):"
    for entry in "${E2E_TRACE_IDS[@]}"; do
      local tid="${entry%%|*}"
      local tname="${entry##*|}"
      echo "     $tname: $tid"
    done
    echo ""
    echo "  Investigar: mise run debug:trace <trace_id>"
    echo "  Console: https://console.cloud.google.com/traces/list?project=garimpo-500114"
  fi

  echo "═══════════════════════════════════════════════"

  if [ "$E2E_FAIL" -gt 0 ]; then
    exit 1
  fi
}
