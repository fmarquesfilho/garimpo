#!/usr/bin/env bash
# mise description="Paridade cross-language: normalizarNome (JS) == Loja.Normalizar (C#)"
set -euo pipefail

echo "═══════════════════════════════════════"
echo "  🔄 test:parity (C# ↔ JS)"
echo "═══════════════════════════════════════"

echo ""
echo "── JS (loja-registry.normalizarNome) ──"
cd web && bunx vitest run src/tests/normalizacao-parity.test.js
cd ..

echo ""
echo "── C# (Loja.Normalizar) ──"
dotnet test src/Garimpei.Tests/Garimpei.Tests.csproj --no-restore \
  --filter "FullyQualifiedName~LojaTests"

echo ""
echo "═══════════════════════════════════════"
echo "  ✅ Paridade confirmada"
echo "═══════════════════════════════════════"
