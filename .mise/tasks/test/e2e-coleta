#!/usr/bin/env bash
# mise description="E2E Coleta: fluxo completo busca agendada → Collector → BigQuery snapshots"
set -euo pipefail

# shellcheck source=.mise/tasks/test/e2e-lib
source "$(dirname "$0")/e2e-lib"

echo "═══════════════════════════════════════════════"
echo "  🔄 E2E Coleta Cross-Service"
echo "═══════════════════════════════════════════════"
echo ""
echo "  Fluxo validado:"
echo "    1. Criar busca com cron (C# API → PostgreSQL → Scheduler gRPC)"
echo "    2. Verificar que Scheduler registrou o job"
echo "    3. Executar coleta (Collector.Fetch via API → Shopee)"
echo "    4. Verificar snapshots no BigQuery (via Analyzer /coletas)"
echo "    5. Verificar isolamento multi-tenant"
echo "    6. Cleanup"
echo ""
echo "  Cada step gera traceparent → rastreável no Cloud Trace"
echo ""

e2e_auth

KEYWORD="e2e-coleta-$(date +%s)"

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 1. Criar busca agendada com traceparent ───"
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "criar-busca-agendada"
echo "     traceparent: $E2E_LAST_TRACEPARENT"

CREATE_RESP=$(e2e_post "/api/buscas" \
  "{\"keywords\":[\"$KEYWORD\"],\"cron\":\"0 */12 * * *\",\"shop_names\":{}}" \
  "$E2E_LAST_TRACEPARENT")

if echo "$CREATE_RESP" | jq -e '.id' > /dev/null 2>&1; then
  BUSCA_ID=$(echo "$CREATE_RESP" | jq -r '.id')
  e2e_ok "Busca criada: $BUSCA_ID (cron: 0 */12 * * *)"
else
  e2e_fail "Criar busca agendada" "$(echo "$CREATE_RESP" | head -c 200)"
  BUSCA_ID=""
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 2. Verificar busca na listagem ────────────"
# ──────────────────────────────────────────────────────────────────────────────

sleep 1
e2e_new_trace "listar-buscas"

LIST_RESP=$(e2e_get "/api/buscas" "$E2E_LAST_TRACEPARENT")
FOUND=$(echo "$LIST_RESP" | jq "[.buscas[] | select(.keywords[]? == \"$KEYWORD\")] | length" 2>/dev/null || echo "0")

if [ "$FOUND" -gt 0 ]; then
  CRON_VAL=$(echo "$LIST_RESP" | jq -r "[.buscas[] | select(.keywords[]? == \"$KEYWORD\")][0].cron")
  e2e_ok "Busca encontrada na listagem (cron: $CRON_VAL)"
else
  e2e_fail "Busca não encontrada na listagem" "keyword=$KEYWORD"
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 3. Executar coleta via Collector.Fetch ────"
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "collector-fetch"
echo "     traceparent: $E2E_LAST_TRACEPARENT"

# Usa keyword real (serum) pois a keyword de teste não tem produtos na Shopee
FETCH_RESP=$(e2e_get "/api/candidatos?keyword=serum&top=5" "$E2E_LAST_TRACEPARENT")
TOTAL_BRUTO=$(echo "$FETCH_RESP" | jq '.total_bruto // 0' 2>/dev/null || echo "0")

if [ "$TOTAL_BRUTO" -gt 0 ]; then
  e2e_ok "Collector.Fetch(serum) retornou $TOTAL_BRUTO produtos"

  # Verifica campos obrigatórios do response
  PRIMEIRO=$(echo "$FETCH_RESP" | jq '.candidatos[0]' 2>/dev/null)
  if echo "$PRIMEIRO" | jq -e '.nome, .preco, .link' > /dev/null 2>&1; then
    e2e_ok "Campos obrigatórios presentes (nome, preco, link)"
  else
    e2e_fail "Campos obrigatórios ausentes no produto" "$(echo "$PRIMEIRO" | head -c 200)"
  fi
else
  e2e_warn "Collector retornou 0 produtos (possível rate limit Shopee)" \
    "Não invalida o fluxo — apenas indica API externa indisponível"
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 4. Verificar coleta por loja (FetchShop) ──"
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "collector-fetchshop"
echo "     traceparent: $E2E_LAST_TRACEPARENT"

# FetchShop usa shop_id=920292999 (Glory of Seoul) do fixtures
SHOP_RESP=$(e2e_get "/api/candidatos?shop_id=920292999&top=5" "$E2E_LAST_TRACEPARENT")
SHOP_TOTAL=$(echo "$SHOP_RESP" | jq '.total_bruto // 0' 2>/dev/null || echo "0")

if [ "$SHOP_TOTAL" -gt 0 ]; then
  e2e_ok "Collector.FetchShop(920292999) retornou $SHOP_TOTAL produtos"
else
  e2e_warn "FetchShop retornou 0 (possível rate limit)" \
    "Shop: Glory of Seoul (920292999)"
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 5. Verificar snapshots no BigQuery ────────"
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "verificar-snapshots-bq"

# Verifica que Analyzer consegue ler coletas (proxy para BigQuery)
COLETAS_RESP=$(e2e_get "/api/coletas?dias=7" "$E2E_LAST_TRACEPARENT")

if echo "$COLETAS_RESP" | grep -q '"coletas"'; then
  COLETA_COUNT=$(echo "$COLETAS_RESP" | jq '.total // 0' 2>/dev/null || echo "0")
  e2e_ok "Analyzer /coletas responde ($COLETA_COUNT coletas na última semana)"

  # Verifica que a coleta tem campos esperados
  if [ "$COLETA_COUNT" -gt 0 ]; then
    COLETA_ITEM=$(echo "$COLETAS_RESP" | jq '.coletas[0]' 2>/dev/null)
    if echo "$COLETA_ITEM" | jq -e '.keyword, .total_produtos, .coletado_em' > /dev/null 2>&1; then
      e2e_ok "Snapshot tem campos obrigatórios (keyword, total_produtos, coletado_em)"
    else
      e2e_warn "Snapshot com campos incompletos" "$(echo "$COLETA_ITEM" | head -c 200)"
    fi
  fi
else
  e2e_fail "Analyzer /coletas indisponível" "$(echo "$COLETAS_RESP" | head -c 200)"
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 6. Verificar estatísticas (BigQuery agg) ──"
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "estatisticas-bq"

STATS_RESP=$(e2e_get "/api/estatisticas" "$E2E_LAST_TRACEPARENT")

if echo "$STATS_RESP" | grep -q '"total_amostras"'; then
  AMOSTRAS=$(echo "$STATS_RESP" | jq '.total_amostras // 0' 2>/dev/null || echo "0")
  e2e_ok "Estatísticas BigQuery: $AMOSTRAS amostras totais"
else
  e2e_fail "Analyzer /estatisticas indisponível" "$(echo "$STATS_RESP" | head -c 200)"
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 7. Isolamento multi-tenant ────────────────"
# ──────────────────────────────────────────────────────────────────────────────

# Endpoints protegidos não devem responder sem auth
e2e_assert_no_leak "/api/buscas" "buscas" "GET /api/buscas requer auth"
e2e_assert_no_leak "/api/coletas" "coletas" "GET /api/coletas requer auth"

# /api/candidatos é público (busca de catálogo, sem dados de owner)
CAND_NOAUTH=$(curl -sf "${E2E_BASE}/api/candidatos?keyword=serum" 2>/dev/null || echo "CURL_FAIL")
if echo "$CAND_NOAUTH" | grep -q '"candidatos"'; then
  e2e_ok "GET /api/candidatos é público (catálogo, sem dados de owner)"
else
  e2e_ok "GET /api/candidatos protegido por auth"
fi

# Verifica que a busca criada pertence ao owner correto
if [ -n "$BUSCA_ID" ]; then
  e2e_new_trace "isolamento-owner"
  BUSCA_DETAIL=$(e2e_get "/api/buscas" "$E2E_LAST_TRACEPARENT")
  OWNER_COUNT=$(echo "$BUSCA_DETAIL" | jq "[.buscas[] | select(.keywords[]? == \"$KEYWORD\")] | length" 2>/dev/null || echo "0")

  if [ "$OWNER_COUNT" -eq 1 ]; then
    e2e_ok "Busca visível apenas para o owner (isolamento via EF Core filter)"
  else
    e2e_fail "Possível vazamento de dados" "Esperado 1 busca com keyword=$KEYWORD, encontrado $OWNER_COUNT"
  fi
fi

# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "── 8. Cleanup ────────────────────────────────"
# ──────────────────────────────────────────────────────────────────────────────

e2e_new_trace "cleanup-busca"
REMOVE_RESP=$(e2e_post "/api/buscas?remover=true" \
  "{\"keywords\":[\"$KEYWORD\"]}" \
  "$E2E_LAST_TRACEPARENT")

if echo "$REMOVE_RESP" | grep -q '"removida"'; then
  e2e_ok "Busca de teste removida"
else
  e2e_warn "Falha ao remover busca de teste" "$(echo "$REMOVE_RESP" | head -c 200)"
fi

# ──────────────────────────────────────────────────────────────────────────────
e2e_summary "E2E Coleta Cross-Service"
