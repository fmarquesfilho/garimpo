{
  "version": "3.0.0",
  "intent": [
    { "keyword": true, "shop": true, "result": "keyword_na_loja", "sources": ["curadoria", "lojas"] },
    { "keyword": true, "shop": false, "result": "keyword_global", "sources": ["curadoria", "quedas", "novos"] },
    { "keyword": false, "shop": true, "result": "loja_completa", "sources": ["lojas", "quedas", "novos"] },
    { "keyword": false, "shop": false, "result": "nenhum", "sources": [] }
  ],
  "contextoCategorias": {
    "sources": ["curadoria", "quedas", "novos"]
  },
  "marketplaces": {
    "suportados": ["shopee", "mercado_livre", "amazon"],
    "default": "shopee",
    "icones": {
      "shopee": "🟠",
      "mercado_livre": "🔵",
      "amazon": "🟡"
    },
    "filtro": {
      "tipo": "toggle_multi",
      "min": 0
    }
  },
  "modos": {
    "explorando": {
      "descricao": "Busca livre, sem vínculo com busca salva",
      "transicoes": {
        "CARREGAR_SALVA": "vinculada",
        "EDITAR_SALVA": "editando"
      }
    },
    "vinculada": {
      "descricao": "Rodando uma busca salva; alterar qualquer parâmetro desvincula",
      "desvinculaEm": [
        "DIGITAR", "ADICIONAR_LOJA", "REMOVER_LOJA",
        "ADICIONAR_CATEGORIA", "REMOVER_CATEGORIA",
        "MUDAR_FILTRO", "MUDAR_FONTES", "MUDAR_MARKETPLACES"
      ],
      "transicoes": {
        "EDITAR_SALVA": "editando",
        "CARREGAR_SALVA": "vinculada"
      }
    },
    "editando": {
      "descricao": "Editando busca salva in-place; salvar atualiza a mesma busca",
      "transicoes": {
        "SALVAR": "explorando",
        "CANCELAR_EDICAO": "explorando",
        "CARREGAR_SALVA": "vinculada"
      }
    }
  },
  "buscaDuplicada": {
    "camposIdentidade": ["keyword", "shopIds", "categorias", "marketplacesFiltro"],
    "normalizacao": {
      "shopIds": "sort",
      "categorias": "sort_lowercase",
      "marketplacesFiltro": "sort"
    },
    "erroAoSalvar": true,
    "feedbackReativo": true
  },
  "lojaRegistro": {
    "normalizacao": "NFD_strip_nonalphanum_lowercase",
    "matchMinChars": 2,
    "fonte": "api"
  },
  "inference": {
    "marketplaces_from_shops": {
      "description": "Se shop_ids contém lojas de um marketplace, esse marketplace é incluído automaticamente.",
      "rule": "marketplaces = union(marketplaces_explicit, marketplaces_inferred_from_shop_ids)"
    },
    "fontes_from_shops": {
      "description": "Se shop_ids não está vazio, 'lojas' é incluído em fontes.",
      "rule": "if shop_ids.length > 0 then fontes must include 'lojas'"
    },
    "marketplace_guard": {
      "description": "Não pode desativar marketplace que tem shops ativos.",
      "rule": "for each marketplace in marketplaces_to_remove: assert no shop_id belongs to that marketplace"
    }
  },
  "derivation": {
    "collection_keys": {
      "description": "Derivado deterministicamente de shop_ids + keywords.",
      "algorithm": "union(shop_ids.map(toString), keywords.map(trim.lowercase)).filter(nonEmpty).sort().dedupe()"
    },
    "tipo": {
      "description": "Derivado dos campos primários populados.",
      "rules": [
        { "condition": "keywords.length > 0 && shop_ids.length == 0 && categorias.length == 0", "result": "keyword" },
        { "condition": "shop_ids.length == 1 && keywords.length == 0", "result": "loja" },
        { "condition": "shop_ids.length > 1 && keywords.length == 0", "result": "loja-multi" },
        { "condition": "categorias.length > 0 && keywords.length == 0 && shop_ids.length == 0", "result": "categoria" },
        { "condition": "keywords.length > 0 && shop_ids.length > 0", "result": "mista" }
      ]
    }
  },
  "omnibox": {
    "prefixos": {
      "@": { "tipo": "loja", "fonte": "lojasMonitoradas", "campo": "nome" },
      "#": { "tipo": "categoria", "fonte": "categoriasDisponiveis", "campo": "nome" },
      "!": { "tipo": "marketplace", "fonte": "marketplaces.suportados", "campo": "nome" }
    },
    "intencao": {
      "habilitado": true,
      "minChars": 2,
      "ordemOpcoes": ["produtos", "lojas", "categorias"],
      "maxCategorias": 3,
      "urlPatterns": ["^https?://"],
      "enterSemSelecao": "primeira_opcao",
      "navegacaoCiclica": true
    },
    "placeholders": {
      "default": "Buscar produtos, lojas ou categorias\u2026",
      "comLoja": "Buscar dentro de {loja}\u2026",
      "comCategoria": "Buscar em {categoria}\u2026"
    },
    "minChars": 2,
    "maxSugestoes": 7,
    "matchBuscaSalva": true,
    "debounceMs": 400
  },
  "guards": {
    "temContextoBusca": { "requiresAny": ["keyword", "shopIds", "categorias"] },
    "podeSalvar": { "requiresAny": ["keyword", "shopIds", "categorias"] }
  },
  "normalize": {
    "comissao": { "divideBy100IfGt1": true, "min": 0, "max": 1, "decimals": 4 },
    "vendas": { "floor": true, "min": 0 }
  },
  "defaults": {
    "comissaoMin": 0.07,
    "vendasMin": 0,
    "fontes": { "curadoria": true, "quedas": true, "novos": true, "lojas": false, "favoritos": false },
    "debounceMs": 400,
    "timeoutMs": 25000,
    "modo": "explorando"
  },
  "transicoes": {
    "DIGITAR": { "refetch": true, "imediato": false },
    "ADICIONAR_LOJA": { "refetch": true, "imediato": true },
    "REMOVER_LOJA": { "refetch": true, "imediato": false },
    "ADICIONAR_CATEGORIA": { "refetch": true, "imediato": true },
    "REMOVER_CATEGORIA": { "refetch": true, "imediato": false },
    "MUDAR_FILTRO": { "refetch": false, "imediato": false },
    "MUDAR_FONTES": { "refetch": true, "imediato": false },
    "MUDAR_MARKETPLACES": { "refetch": true, "imediato": false },
    "CARREGAR_SALVA": { "refetch": true, "imediato": true },
    "CANCELAR_EDICAO": { "refetch": false, "imediato": true },
    "OMNIBOX_INPUT": { "refetch": false, "imediato": false },
    "OMNIBOX_KEYDOWN": { "refetch": false, "imediato": true },
    "OMNIBOX_SELECIONAR": { "refetch": false, "imediato": true },
    "BUSCAR_LOJAS": { "refetch": true, "imediato": true },
    "MONITORAR_LOJA": { "refetch": true, "imediato": true }
  },
  "feedDefault": {
    "habilitado": true,
    "estrategia": "categoria_top_vendidos",
    "categorias": [
      { "marketplace": "shopee", "categoryId": 100630, "nome": "Beleza", "keyword": "beleza" },
      { "marketplace": "shopee", "categoryId": 100664, "nome": "Cuidados com a Pele", "keyword": "skincare" },
      { "marketplace": "shopee", "categoryId": 100640, "nome": "Perfumaria", "keyword": "perfume" }
    ],
    "rotacao": "random",
    "limit": 20,
    "sortBy": "sales"
  },
  "storeCard": {
    "camposVisiveis": {
      "shopee": ["imagem", "nome", "origem", "seguidores", "total_produtos", "avaliacao", "monitorada"],
      "mercado_livre": ["imagem", "nome", "origem", "monitorada"],
      "amazon": ["imagem", "nome", "origem", "monitorada"],
      "_fallback": ["nome", "marketplace", "monitorada"]
    },
    "layout": "horizontal",
    "acoes": ["monitorar"]
  }
}
