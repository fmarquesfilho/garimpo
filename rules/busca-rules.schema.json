{
  "type": "object",
  "required": ["version", "intent", "guards", "normalize", "defaults", "transicoes", "modos", "buscaDuplicada"],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "intent": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["keyword", "shop", "result", "sources"],
        "properties": {
          "keyword": { "type": "boolean" },
          "shop": { "type": "boolean" },
          "result": { "type": "string", "enum": ["keyword_na_loja", "keyword_global", "loja_completa", "nenhum"] },
          "sources": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "contextoCategorias": {
      "type": "object",
      "required": ["sources"],
      "properties": {
        "sources": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "marketplaces": {
      "type": "object",
      "required": ["suportados", "default"],
      "properties": {
        "suportados": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "default": { "type": "string" },
        "icones": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "filtro": {
          "type": "object",
          "properties": {
            "tipo": { "type": "string" },
            "min": { "type": "integer" }
          }
        }
      },
      "additionalProperties": false
    },
    "modos": {
      "type": "object",
      "required": ["explorando", "vinculada", "editando"],
      "additionalProperties": {
        "type": "object",
        "required": ["descricao"],
        "properties": {
          "descricao": { "type": "string" },
          "desvinculaEm": {
            "type": "array",
            "items": { "type": "string" }
          },
          "transicoes": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "enum": ["explorando", "vinculada", "editando"]
            }
          }
        },
        "additionalProperties": false
      }
    },
    "buscaDuplicada": {
      "type": "object",
      "required": ["camposIdentidade", "normalizacao", "erroAoSalvar", "feedbackReativo"],
      "properties": {
        "camposIdentidade": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "normalizacao": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "erroAoSalvar": { "type": "boolean" },
        "feedbackReativo": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "omnibox": {
      "type": "object",
      "description": "Config do input unificado (omnibox) da página Descobrir.",
      "required": ["prefixos", "minChars", "maxSugestoes", "matchBuscaSalva", "debounceMs"],
      "properties": {
        "prefixos": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["tipo", "fonte", "campo"],
            "properties": {
              "tipo": { "type": "string", "enum": ["loja", "categoria", "marketplace"] },
              "fonte": { "type": "string" },
              "campo": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "minChars": { "type": "integer", "minimum": 1 },
        "maxSugestoes": { "type": "integer", "minimum": 1 },
        "matchBuscaSalva": { "type": "boolean" },
        "debounceMs": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "guards": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "requiresAny": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["requiresAny"]
      }
    },
    "normalize": {
      "type": "object",
      "properties": {
        "comissao": {
          "type": "object",
          "required": ["divideBy100IfGt1", "min", "max", "decimals"],
          "properties": {
            "divideBy100IfGt1": { "type": "boolean" },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "decimals": { "type": "integer" }
          }
        },
        "vendas": {
          "type": "object",
          "required": ["floor", "min"],
          "properties": {
            "floor": { "type": "boolean" },
            "min": { "type": "number" }
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "required": ["comissaoMin", "vendasMin", "fontes", "debounceMs", "timeoutMs", "modo"],
      "properties": {
        "comissaoMin": { "type": "number" },
        "vendasMin": { "type": "number" },
        "fontes": { "type": "object" },
        "debounceMs": { "type": "integer" },
        "timeoutMs": { "type": "integer" },
        "modo": { "type": "string", "enum": ["explorando", "vinculada", "editando"] }
      }
    },
    "transicoes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["refetch", "imediato"],
        "properties": {
          "refetch": { "type": "boolean" },
          "imediato": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "inference": {
      "type": "object",
      "description": "Regras de inferência declarativas (shop→marketplace, shop→fontes, guard).",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "rule"],
        "properties": {
          "description": { "type": "string" },
          "rule": { "type": "string" }
        }
      }
    },
    "derivation": {
      "type": "object",
      "description": "Regras de derivação de campos computados (collection_keys, tipo).",
      "properties": {
        "collection_keys": {
          "type": "object",
          "required": ["description", "algorithm"],
          "properties": {
            "description": { "type": "string" },
            "algorithm": { "type": "string" }
          }
        },
        "tipo": {
          "type": "object",
          "required": ["description", "rules"],
          "properties": {
            "description": { "type": "string" },
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["condition", "result"],
                "properties": {
                  "condition": { "type": "string" },
                  "result": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
