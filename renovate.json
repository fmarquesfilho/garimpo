{
  "extends": [
    "config:recommended",
    "group:monorepos",
    ":automergeMinor",
    ":automergePatch",
    "schedule:earlyMondays"
  ],
  "labels": ["dependencies"],
  "platformAutomerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 4,
  "rebaseWhen": "behind-base-branch",
  "separateMajorMinor": false,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Auto-merge all updates if CI passes",
      "matchUpdateTypes": ["patch", "pin", "digest", "minor", "major"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Label major updates for visibility",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"]
    },
    {
      "description": "Agrupar deps do frontend (web)",
      "matchFileNames": ["web/package.json"],
      "groupName": "web dependencies",
      "groupSlug": "web-deps"
    },
    {
      "description": "Agrupar deps do docs-site",
      "matchFileNames": ["docs-site/package.json"],
      "groupName": "docs-site dependencies",
      "groupSlug": "docs-deps",
      "schedule": ["before 9am on the first day of the month"]
    },
    {
      "description": "Agrupar deps Python (analyzer)",
      "matchManagers": ["pip_requirements"],
      "groupName": "python dependencies",
      "groupSlug": "python-deps"
    },
    {
      "description": "Agrupar Go dependencies",
      "matchManagers": ["gomod"],
      "groupName": "go dependencies",
      "groupSlug": "go-deps"
    },
    {
      "description": "Agrupar GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "groupSlug": "gha-deps"
    },
    {
      "description": "Agrupar NuGet (C#)",
      "matchManagers": ["nuget"],
      "groupName": "dotnet dependencies",
      "groupSlug": "dotnet-deps"
    },
    {
      "description": "Agrupar Docker images",
      "matchManagers": ["dockerfile"],
      "groupName": "docker images",
      "groupSlug": "docker-deps"
    },
    {
      "description": "Ignorar pacotes do Astro (migrado para Rspress)",
      "matchFileNames": ["docs-site/package.json"],
      "matchPackageNames": ["/^@astrojs//", "/^astro$/", "/^sharp$/"],
      "enabled": false
    }
  ],
  "ignorePaths": [
    "gen/**",
    "web/node_modules/**",
    "docs-site/node_modules/**"
  ]
}
