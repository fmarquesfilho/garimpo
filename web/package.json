{
  "name": "garimpo-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json --threshold error --output human",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:css": "stylelint 'src/**/*.svelte' 'src/**/*.css' --custom-syntax=postcss-html",
    "lint:js": "eslint src/ --max-warnings=0",
    "lint:dead": "knip",
    "lint:a11y": "svelte-check --tsconfig ./tsconfig.json --threshold warning --compiler-warnings 'a11y-*'",
    "audit:ui": "bash scripts/audit-ui-coverage.sh",
    "lint": "npm run check && npm run lint:css && npm run lint:js",
    "precheck": "npm run check && npm run lint:css && npm run lint:js && npm run lint:dead && npm run build && npm run test:unit",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "axe-core": "^4.12.1",
    "csstype": "^3.2.3",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "knip": "^6.20.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "bits-ui": "^2.18.1",
    "firebase": "^12.15.0"
  }
}
