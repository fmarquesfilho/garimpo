{
	"name": "garimpo-web",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"format": "prettier --write src/ tests/",
		"format:check": "prettier --check src/ tests/",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold warning --output human --fail-on-warnings",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint:css": "stylelint 'src/**/*.svelte' 'src/**/*.css' --custom-syntax=postcss-html",
		"lint:js": "eslint src/ --max-warnings=0",
		"lint:dead": "knip",
		"lint:security": "semgrep scan --config p/javascript --config p/typescript --error --exclude node_modules --exclude .svelte-kit --exclude build src/",
		"lint:a11y": "svelte-check --tsconfig ./tsconfig.json --threshold warning --compiler-warnings 'a11y-*'",
		"audit:ui": "bash scripts/audit-ui-coverage.sh",
		"lint": "npm run check && npm run lint:css && npm run lint:js",
		"ci:local": "npm run check && npm run lint:css && npm run lint:js && npm audit --audit-level=high && npm run lint:dead && npm run build && npm run test:unit",
		"test": "playwright test",
		"test:unit": "vitest run",
		"test:e2e:local": "playwright test --config=playwright.local.config.js",
		"test:e2e:prod": "playwright test --config=playwright.prod.config.js",
		"test:ui": "playwright test --ui"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"axe-core": "^4.12.1",
		"clsx": "^2.1.1",
		"csstype": "^3.2.3",
		"dotenv": "^16.5.0",
		"eslint": "^10.5.0",
		"eslint-plugin-svelte": "^3.19.0",
		"fast-check": "^4.8.0",
		"jsdom": "^29.1.1",
		"knip": "^6.20.0",
		"postcss-html": "^1.8.1",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"stylelint": "^17.14.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vitest": "^4.1.9",
		"vitest-axe": "^0.1.0"
	},
	"dependencies": {
		"@opentelemetry/core": "^2.9.0",
		"@opentelemetry/instrumentation": "^0.220.0",
		"@opentelemetry/instrumentation-fetch": "^0.220.0",
		"@opentelemetry/resources": "^2.9.0",
		"@opentelemetry/sdk-trace-base": "^2.9.0",
		"@opentelemetry/sdk-trace-web": "^2.9.0",
		"@opentelemetry/semantic-conventions": "^1.43.0",
		"@tiptap/core": "^3.27.1",
		"@tiptap/extension-link": "^3.27.1",
		"@tiptap/extension-placeholder": "^3.27.1",
		"@tiptap/starter-kit": "^3.27.1",
		"bits-ui": "^2.18.1",
		"d3-scale": "4.0.2",
		"firebase": "^12.15.0",
		"layerchart": "2.0.1"
	}
}
